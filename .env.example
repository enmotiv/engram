ENGRAM_EMBEDDING_DIMENSIONS=1024
ENGRAM_LLM_MODEL=openai/gpt-4o-mini
ENGRAM_API_PORT=8000
ENGRAM_LOG_LEVEL=INFO
ENGRAM_EXTENSIONS=
ENGRAM_RETRIEVAL_EXCLUDE_TAGS=
